#!/usr/bin/env python3

import re
import shutil
import subprocess
import sys
from collections import Counter


WIDTH = min(shutil.get_terminal_size().columns, 80)
_FF_PATTERN = re.compile(r"revert|fix|hotfix|emergency|rollback|bug|broken", re.IGNORECASE)


def git(*args):
    try:
        return subprocess.check_output(
            ["git", *args], text=True, stderr=subprocess.DEVNULL
        )
    except subprocess.CalledProcessError:
        return ""


def header(title):
    line = "─" * WIDTH
    print(f"\n{line}")
    print(title)
    print(line)


def bar(value, max_value, width=30):
    if max_value == 0:
        return ""
    filled = int(value / max_value * width)
    return "█" * filled + "░" * (width - filled)


def count_lines(text, limit=30):
    counts = Counter(line for line in text.strip().splitlines() if line.strip())
    return [(count, name) for name, count in counts.most_common(limit)]


def print_ranked(entries, bar_width=20):
    if not entries:
        print("  (no data)")
        return
    max_val = entries[0][0]
    for count, name in entries:
        print(f"  {bar(count, max_val, bar_width)}  {count:>5}  {name}")


def section_contributors():
    header("Contributor activity")
    raw = git("log", "--format=%aN", "--no-merges")
    print_ranked(count_lines(raw, limit=20))


def section_churn():
    header("Churn hotspots")
    raw = git("log", "--format=format:", "--name-only")
    print_ranked(count_lines(raw))


def section_bugs():
    header("Bug clustering")
    raw = git(
        "log", "-i", "-E", "--grep=fix|bug|broken", "--name-only", "--format=",
    )
    print_ranked(count_lines(raw))


def section_velocity_and_firefighting():
    header("Velocity and firefighting")
    raw = git("log", "--format=%ad\t%s", "--date=format:%Y-%m")
    if not raw.strip():
        print("  (no data)")
        return

    velocity = Counter()
    firefighting = Counter()
    for line in raw.splitlines():
        if not line.strip():
            continue
        month, _, subject = line.partition("\t")
        velocity[month] += 1
        if _FF_PATTERN.search(subject):
            firefighting[month] += 1

    max_vel = max(velocity.values())
    max_ff = max(firefighting.values(), default=1)
    bar_width = (WIDTH - 24) // 2

    for month in sorted(velocity, reverse=True):
        vel = velocity[month]
        ff = firefighting[month]
        print(
            f"  {month}  "
            f"{vel:>4}  {bar(vel, max_vel, bar_width)}  "
            f"{ff:>3}  {bar(ff, max_ff, bar_width)}"
        )


def main():
    if not git("rev-parse", "--is-inside-work-tree"):
        print("fatal: not a git repository", file=sys.stderr)
        sys.exit(1)

    section_contributors()
    section_churn()
    section_bugs()
    section_velocity_and_firefighting()
    print()


if __name__ == "__main__":
    main()
